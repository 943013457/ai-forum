# ==================== 数据库配置 ====================
POSTGRES_HOST=postgres          # 数据库主机名（Docker 服务名）
POSTGRES_PORT=5432              # 数据库端口
POSTGRES_DB=ai_forum            # 数据库名称
POSTGRES_USER=ai_forum          # 数据库用户名
POSTGRES_PASSWORD=123456      # 数据库密码（请修改）

# ==================== LLM 大语言模型（OpenAI 兼容接口） ====================
LLM_API_BASE_URL=https://api.siliconflow.cn/v1  # LLM API 地址
LLM_API_KEY=your-llm-api-key                      # LLM API 密钥
LLM_MODEL_NAME=Qwen/Qwen2.5-14B-Instruct                             # LLM 模型名称

# ==================== Embedding 向量嵌入模型 ====================
EMBEDDING_API_BASE_URL=https://api.siliconflow.cn/v1  # Embedding API 地址
EMBEDDING_API_KEY=your-embedding-api-key               # Embedding API 密钥
EMBEDDING_MODEL=BAAI/bge-m3                            # 向量模型名称（多语言，中文优秀，1024维）

# ==================== 图像生成（Kolors 生图模型） ====================
IMAGE_GEN_API_BASE_URL=https://api.siliconflow.cn/v1  # 生图 API 地址
IMAGE_GEN_API_KEY=your-image-gen-api-key               # 生图 API 密钥
IMAGE_GEN_MODEL=Kwai-Kolors/Kolors                     # 生图模型名称
IMAGE_SIZE=1024x1024                                   # 生成图片分辨率
IMAGE_INFERENCE_STEPS=20                               # 推理步数（越高质量越好，速度越慢）
IMAGE_GUIDANCE_SCALE=7.5                               # 提示词引导强度（越高越贴合提示词）

# ==================== 视觉识别模型（Qwen VL） ====================
VISION_API_BASE_URL=https://api.siliconflow.cn/v1  # 视觉模型 API 地址
VISION_API_KEY=your-vision-api-key                  # 视觉模型 API 密钥
VISION_MODEL=Qwen/Qwen2-VL-72B-Instruct                       # 视觉模型名称（识别图片内容）

# ==================== UapiPro 服务 ====================
UAPI_BASE_URL=https://uapis.cn/api/v1
UAPI_KEY=uapi-your-key-here    # UapiPro API Key

# ==================== 世界引擎节奏 ====================
TICK_INTERVAL_SECONDS=90       # 每个世界刻的间隔（秒），即多久模拟一轮
ACTIVE_USERS_PER_TICK=50       # 每个世界刻随机激活的 AI 用户数量
MAX_LLM_CALLS_PER_HOUR=400    # 每小时 LLM 调用次数硬上限（令牌桶限速）

# ==================== AI 用户行为概率 ====================
COMMENT_PROBABILITY=0.12       # 对感兴趣的帖子发表评论的概率
POST_PROBABILITY=0.02          # 每个活跃用户每刻自发发帖的概率
POST_IMAGE_PROBABILITY=0.10    # 发帖时附带生成配图的概率
IMAGE_ONLY_POST_PROBABILITY=0.03  # 发布纯图片帖（无正文）的概率
LIKE_BASE_PROBABILITY=0.25     # 对感兴趣帖子点赞的基础概率
ENTROPY_RATIO=0.05             # 推荐流中随机混入无关帖子的比例（防止信息茧房）

# ==================== 文章/评论字数 ====================
POST_MIN_LENGTH=20            # 文章正文最少字数
POST_MAX_LENGTH=2000            # 文章正文最多字数
COMMENT_MIN_LENGTH=5          # 评论最少字数
COMMENT_MAX_LENGTH=100         # 评论最多字数

# ==================== 推荐算法权重 ====================
FEED_MATCH_WEIGHT=0.60         # 兴趣匹配度权重（用户兴趣 vs 帖子内容）
FEED_HOT_WEIGHT=0.25           # 帖子热度权重（点赞/评论/浏览综合）
FEED_CREDIT_WEIGHT=0.15        # 作者积分权重（高积分作者曝光加成）
FEED_TOP_N=5                   # 每次推荐给用户的帖子数量

# ==================== 热度公式参数 ====================
HOT_LIKE_WEIGHT=2              # 每个点赞的热度权重
HOT_COMMENT_WEIGHT=5           # 每条评论的热度权重
HOT_VIEW_WEIGHT=0.1            # 每次浏览的热度权重
HOT_DECAY_POWER=1.5            # 时间衰减指数（越大越快过气）

# ==================== 积分系统 ====================
FEATURED_POST_REWARD=50        # 文章被精选时奖励的积分
CREDIT_SETTLE_ENABLED=true     # 是否启用每 Tick 自动积分结算

# ==================== AI 用户生成参数 ====================
PERSONA_MIN_AGE=15             # 生成用户的最小年龄
PERSONA_MAX_AGE=80             # 生成用户的最大年龄
PERSONA_BATCH_SIZE=50          # 每次批量生成用户的数量

# ==================== 关系网络 ====================
AUTO_FOLLOW_INTERACTION_THRESHOLD=3   # 互动达到此次数后自动互关
FOLLOW_FEED_BOOST=1.5                 # 关注用户的帖子在 Feed 中的权重加成倍数

# ==================== 情绪系统 ====================
MOOD_ENABLED=true              # 是否启用情绪系统
MOOD_DECAY_RATE=0.05           # 情绪每 Tick 自然回归中性的速率

# ==================== 头像生成模式 ====================
AVATAR_MODE=api                # api=使用UapiPro随机图片, model=使用生图模型
AVATAR_MAX_SIZE=256            # 头像压缩后最大边长(像素)
AVATAR_QUALITY=80              # JPEG压缩质量(1-100)

# ==================== 新闻热榜 ====================
NEWS_ENABLED=true              # 启用后定时获取热点新闻并发布
NEWS_SCHEDULE_HOURS=8,12,15,18,20,0  # 定时获取新闻的小时(逗号分隔)
NEWS_TOP_N=5                   # 每次获取热榜前N条

# ==================== 热点事件注入 ====================
HOT_EVENT_ENABLED=true         # 是否启用自动热点事件注入

# ==================== 每日话题 ====================
DAILY_TOPIC_ENABLED=true       # 是否启用每日话题自动生成
DAILY_TOPIC_HOUR=8             # 每天几点生成新话题（24小时制）

# ==================== 称号/成就系统 ====================
ACHIEVEMENT_ENABLED=true       # 是否启用自动称号授予

# ==================== 用户生命周期 ====================
LIFECYCLE_ENABLED=true         # 是否启用用户生命周期系统
LIFECYCLE_NEWBIE_DAYS=7        # 新手期持续天数
LIFECYCLE_ACTIVE_DAYS=30       # 活跃期持续天数（随机波动±30%）
LIFECYCLE_FATIGUE_DAYS=20      # 倦怠期持续天数
LIFECYCLE_AUTO_SPAWN_RATE=5    # 每天自动新增的用户数

# ==================== 昼夜节律 ====================
DAY_NIGHT_ENABLED=true         # 是否启用昼夜节律系统
DAYTIME_ACTIVE_RATIO=1.0       # 白天 (8-18点) 在线用户比例倍率
EVENING_ACTIVE_RATIO=0.8       # 晚上 (18-24点) 在线用户比例倍率
LATE_NIGHT_ACTIVE_RATIO=0.2    # 深夜 (0-3点) 在线用户比例倍率
DEAD_NIGHT_ACTIVE_RATIO=0.05   # 凌晨 (3-8点) 在线用户比例倍率

# ==================== 谣言传播 ====================
RUMOR_ENABLED=true             # 是否启用谣言传播系统
RUMOR_SPREAD_PROBABILITY=0.15  # 轻信型用户转发谣言的概率
RUMOR_DEBUNK_PROBABILITY=0.30  # 理性型用户辟谣的概率

# ==================== 投票帖 ====================
POLL_POST_PROBABILITY=0.05     # 发帖时发起投票帖的概率
POLL_MAX_OPTIONS=4             # 投票帖最大选项数

# ==================== 对线/约架 ====================
DEBATE_ENABLED=true            # 是否启用自动约架系统
DEBATE_TRIGGER_REPLIES=3       # 互怀超过此次数触发约架
DEBATE_ROUNDS=5                # 约架轮数（每人交替发言）
DEBATE_WIN_REWARD=20           # 赢家积分奖励
DEBATE_LOSE_PENALTY=10         # 输家积分惩罚

# ==================== 多语言用户 ====================
MULTILANG_ENABLED=true         # 是否启用多语言用户
FOREIGN_USER_RATIO=0.05        # 生成用户时外国人的比例

# ==================== 小号/潜水党 ====================
ALT_ACCOUNT_RATIO=0.08         # 拥有小号的用户比例
LURKER_RATIO=0.15              # 潜水党用户比例（只看不发）
REPOSTER_RATIO=0.10            # 转发党用户比例（只转不创）

# ==================== 存储路径 ====================
DATA_DIR=/data                 # 数据根目录
AVATAR_DIR=/data/avatars       # 头像图片存储目录
POST_IMAGE_DIR=/data/post_images  # 帖子配图存储目录

# ==================== 管理员账号 ====================
ADMIN_USERNAME=admin           # 管理员用户名
ADMIN_PASSWORD=admin        # 管理员密码（请修改）

# ==================== 服务端口 ====================
BACKEND_PORT=8000              # 后端 API 端口
FRONTEND_PORT=3000             # 前端开发端口
NGINX_PORT=80                  # Nginx 对外暴露端口
